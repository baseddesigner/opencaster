<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %> · Farcaster Lite</title>
  <link rel="stylesheet" href="/app.css">
</head>
<body>
  <%- include('../partials/header', { active }) %>
  <main class="app-shell single-column">
    <% if (setupMessage) { %><%- include('../partials/empty-state', { message: setupMessage }) %><% } %>
    <% if (errorMessage) { %><%- include('../partials/error-state', { message: errorMessage }) %><% } %>
    <% if (profile) { %>
      <%- include('../partials/profile-card', { profile }) %>
      <div class="toolbar stacked-toolbar">
        <div class="segmented" aria-label="Display">
          <span>Display</span>
          <% Object.entries(displayModes).forEach(([modeId, mode]) => { %>
            <a class="<%= displayMode === modeId ? 'active' : '' %>" href="<%= displayModeHref(modeId) %>" title="<%= mode.description %>"><%= mode.label %></a>
          <% }) %>
        </div>
      </div>
      <section class="discovery-module" aria-label="Author recent casts">
        <div class="section-head">
          <div>
            <h2>Author's recent casts</h2>
            <% if (discovery.recentWhy) { %><p class="module-note"><%= discovery.recentWhy %></p><% } %>
          </div>
          <a class="text-link" href="/search?q=<%= encodeURIComponent(profile.username) %>&type=casts">Search mentions</a>
        </div>
        <div class="feed-list display-<%= displayMode %>">
          <% casts.forEach((cast) => { %><%- include('../partials/feed-card', { cast: { ...cast, whyShown: discovery.recentWhy }, displayMode }) %><% }) %>
          <% if (!casts.length) { %><%- include('../partials/empty-state', { message: 'No recent casts loaded for this profile.' }) %><% } %>
        </div>
      </section>
      <section class="discovery-module" aria-label="Related casts">
        <div class="section-head">
          <div>
            <h2>Related casts</h2>
            <% if (discovery.relatedQuery) { %><p class="module-note">Search query: <code><%= discovery.relatedQuery %></code></p><% } %>
          </div>
          <% if (discovery.relatedQuery) { %><a class="text-link" href="/search?q=<%= encodeURIComponent(discovery.relatedQuery) %>&type=casts">Open search</a><% } %>
        </div>
        <div class="feed-list">
          <% discovery.relatedCasts.forEach((cast) => { %><%- include('../partials/feed-card', { cast }) %><% }) %>
          <% if (!discovery.relatedCasts.length) { %><%- include('../partials/empty-state', { message: 'No related casts loaded for this profile.' }) %><% } %>
        </div>
      </section>
    <% } %>
  </main>
  <script src="/app.js"></script>
</body>
</html>

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %> · Farcaster Lite</title>
  <link rel="stylesheet" href="/app.css">
</head>
<body>
  <%- include('../partials/header', { active }) %>
  <main class="app-shell single-column">
    <% if (setupMessage) { %><%- include('../partials/empty-state', { message: setupMessage }) %><% } %>
    <% if (errorMessage) { %><%- include('../partials/error-state', { message: errorMessage }) %><% } %>
    <% if (profile) { %>
      <%- include('../partials/profile-card', { profile }) %>
      <div class="section-head"><h2>Recent casts</h2><a class="text-link" href="/search?q=<%= encodeURIComponent(profile.username) %>&type=casts">Search mentions</a></div>
      <section class="feed-list">
        <% casts.forEach((cast) => { %><%- include('../partials/feed-card', { cast }) %><% }) %>
        <% if (!casts.length) { %><%- include('../partials/empty-state', { message: 'No recent casts loaded for this profile.' }) %><% } %>
      </section>
    <% } %>
  </main>
  <script src="/app.js"></script>
</body>
</html>

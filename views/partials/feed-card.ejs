<article class="cast-card">
  <div class="cast-topline">
    <a class="cast-author" href="/u/<%= encodeURIComponent(cast.author.username) %>">
      <img class="avatar" src="<%= cast.author.pfpUrl %>" alt="" loading="lazy">
      <span>
        <strong class="author-name"><%= cast.author.displayName %></strong>
        <span class="muted">@<%= cast.author.username %> · <%= cast.timestampLabel %></span>
      </span>
    </a>
    <span class="signal-chip" title="Engagement score"><%= cast.engagementScoreLabel || '0' %></span>
  </div>
  <p class="cast-text"><%= cast.text %></p>
  <% if (cast.embeds && cast.embeds.length) { %>
    <div class="embeds">
      <% cast.embeds.forEach((embed) => { %>
        <a href="<%= embed.url %>" target="_blank" rel="noopener noreferrer"><span>↗</span><%= embed.label %></a>
      <% }) %>
    </div>
  <% } %>
  <div class="cast-meta" aria-label="Cast stats">
    <span><strong><%= cast.replyCountLabel %></strong> replies</span>
    <span><strong><%= cast.recastCountLabel %></strong> recasts</span>
    <span><strong><%= cast.likeCountLabel %></strong> likes</span>
  </div>
  <div class="actions">
    <a href="/cast/<%= encodeURIComponent(cast.hash) %>">View thread</a>
    <a href="<%= cast.farcasterUrl %>" target="_blank" rel="noopener noreferrer">Open in Farcaster</a>
  </div>
</article>

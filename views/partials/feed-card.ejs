<article class="cast-card <%= (typeof displayMode !== 'undefined' && displayMode === 'grid') ? 'compact-card' : '' %>" data-cast-card data-cast-url="/cast/<%= encodeURIComponent(cast.hash) %>" tabindex="-1">
  <%- include('./cast-summary', { cast, showScore: true, showThreadLink: false }) %>
  <% if (cast.isReply || cast.isRecast) { %>
    <div class="cast-badges" aria-label="Cast context">
      <% if (cast.isReply) { %><span class="pill subtle">Reply</span><% } %>
      <% if (cast.isRecast) { %><span class="pill subtle">Recast</span><% } %>
    </div>
  <% } %>
  <% if (cast.whyShown) { %>
    <p class="why-shown"><span>Why shown</span><%= cast.whyShown %></p>
  <% } %>
  <% if (cast.imageEmbeds && cast.imageEmbeds.length) { %>
    <div class="image-grid count-<%= Math.min(cast.imageEmbeds.length, 4) %>" aria-label="Image embeds">
      <% cast.imageEmbeds.slice(0, 4).forEach((embed, index) => { %>
        <a class="image-tile" href="<%= embed.url %>" target="_blank" rel="noopener noreferrer">
          <% if (embed.imageUrl) { %><img src="<%= embed.imageUrl %>" alt="" loading="lazy"><% } %>
          <% if (index === 3 && cast.imageEmbeds.length > 4) { %><span class="image-more">+<%= cast.imageEmbeds.length - 4 %></span><% } %>
        </a>
      <% }) %>
    </div>
  <% } %>
  <% if (cast.detailEmbeds && cast.detailEmbeds.length) { %>
    <div class="embeds rich-embeds">
      <% cast.detailEmbeds.forEach((embed) => { %>
        <%- include('./embed-card', { embed }) %>
      <% }) %>
    </div>
  <% } %>
  <div class="cast-meta" aria-label="Cast stats">
    <span><strong><%= cast.replyCountLabel %></strong> replies</span>
    <span><strong><%= cast.recastCountLabel %></strong> recasts</span>
    <span><strong><%= cast.likeCountLabel %></strong> likes</span>
  </div>
  <div class="actions">
    <a href="/cast/<%= encodeURIComponent(cast.hash) %>">View thread</a>
    <a href="<%= cast.replyUrl %>" target="_blank" rel="noopener noreferrer">Reply in Farcaster</a>
    <a href="<%= cast.authorSearchUrl %>">More from @<%= cast.author.username %></a>
    <a href="<%= cast.farcasterUrl %>" target="_blank" rel="noopener noreferrer">Open in Farcaster</a>
  </div>
</article>

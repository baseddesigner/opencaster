{
  "name": "farcaster-lite-client",
  "version": "0.1.0",
  "description": "No-build read-only Farcaster client using Express and EJS",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "test": "node --test tests/*.test.js",
    "check": "node --check src/server.js && node --test tests/*.test.js"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "ejs": "^3.1.10",
    "express": "^5.1.0",
    "lru-cache": "^11.2.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "supertest": "^7.1.4"
  }
}

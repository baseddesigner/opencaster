{
  "name": "farcaster-lite-client",
  "version": "0.1.0",
  "description": "No-build, read-only Farcaster client using Express, EJS, and server-side providers.",
  "license": "MIT",
  "main": "src/server.js",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baseddesigner/opencaster.git"
  },
  "bugs": {
    "url": "https://github.com/baseddesigner/opencaster/issues"
  },
  "homepage": "https://github.com/baseddesigner/opencaster#readme",
  "keywords": [
    "farcaster",
    "social-client",
    "express",
    "ejs",
    "hypersnap",
    "neynar",
    "read-only"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "test": "node --test tests/*.test.js",
    "check": "node --check src/server.js && node --check scripts/smoke.js && node --check scripts/mobile-cdp-qa.js && node --test tests/*.test.js",
    "smoke": "node scripts/smoke.js",
    "local:dev:start": "scripts/local-dev.sh start",
    "local:dev:stop": "scripts/local-dev.sh stop",
    "local:dev:restart": "scripts/local-dev.sh restart",
    "local:dev:rebuild": "scripts/local-dev.sh rebuild",
    "local:dev:logs": "scripts/local-dev.sh logs",
    "local:dev:status": "scripts/local-dev.sh status"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "ejs": "^3.1.10",
    "express": "^5.1.0",
    "lru-cache": "^11.2.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "supertest": "^7.1.4"
  }
}

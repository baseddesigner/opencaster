# Defaults to no-secret demo mode.
FARCASTER_PROVIDER=demo

# Optional no-key live reads. Switch FARCASTER_PROVIDER=hypersnap to use it.
HYPERSNAP_BASE_URL=https://haatz.quilibrium.com
HYPERSNAP_VIEWER_FID=1325

# Optional for Neynar-backed live reads. Never expose to browser.
NEYNAR_API_KEY=

# Optional; defaults are safe for local dev.
PORT=3039
HOST=127.0.0.1
NODE_ENV=development

# Feed config
DEFAULT_FEED=builders
CACHE_TTL_SECONDS=60

# If set later, controls links back to public app URL.
PUBLIC_BASE_URL=http://127.0.0.1:3039

# Required for Neynar-backed reads. Never expose to browser.
NEYNAR_API_KEY=replace_me

# Optional; defaults are safe for local dev.
PORT=3039
HOST=127.0.0.1
NODE_ENV=development

# Feed config
DEFAULT_FEED=builders
CACHE_TTL_SECONDS=60

# If set later, controls links back to public app URL.
PUBLIC_BASE_URL=http://127.0.0.1:3039
